# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Redis (optionnel pour le MVP — SQLite seul suffit si Redis non dispo)
REDIS_URL=redis://localhost:6379/0

# Base de données (SQLite par défaut pour le MVP)
DATABASE_URL=sqlite:///./kontract.db

# Supabase Auth (V1 — pas nécessaire pour le MVP)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key

# Stripe (V1 — pas nécessaire pour le MVP)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
